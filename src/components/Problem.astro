---
---
<section
  id="probleme"
  class="bg-cn-cream py-28 md:py-section overflow-hidden"
  aria-labelledby="problem-heading"
>
  <div class="px-6 md:px-10">
  <div class="max-w-6xl mx-auto">

    <!-- Stat block -->
    <div class="text-center mb-20">
      <p class="font-montserrat text-cn-sage text-xs tracking-[0.25em] uppercase mb-6">Le constat</p>
      <div class="flex items-baseline justify-center gap-1 mb-6">
        <span
          id="stat-number"
          class="font-seasons text-cn-green"
          data-target="63"
          style="font-size: clamp(5rem, 15vw, 10rem); line-height: 1;"
        >0</span>
        <span class="font-seasons text-cn-bronze" style="font-size: clamp(3rem, 8vw, 6rem); line-height: 1;">%</span>
      </div>
      <p id="stat-label" class="gsap-hidden font-inria text-cn-charcoal/70 text-lg max-w-2xl mx-auto leading-relaxed">
        des collaborateurs quittent leur entreprise à cause<br class="hidden md:block" />
        d'une mauvaise communication interne
      </p>
      <p class="font-montserrat text-cn-charcoal/35 text-xs mt-3 tracking-wide">Source : Gallup State of the Global Workplace</p>
    </div>

    <!-- Pain point cards -->
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      <!-- Card 1 -->
      <article class="pain-card gsap-hidden bg-white/70 p-8 border border-cn-charcoal/8 hover:border-cn-bronze/40 transition-colors duration-500">
        <div class="mb-5">
          <svg class="w-8 h-8 text-cn-bronze" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <h3 class="font-seasons text-cn-charcoal mb-3" style="font-size: clamp(1.25rem, 2.5vw, 1.6rem);">L'isolement invisible</h3>
        <p class="font-inria text-cn-charcoal/65 text-base leading-relaxed">
          Quand les liens se distendent, la performance cognitive chute silencieusement — sans alarme, sans signal visible.
        </p>
      </article>

      <!-- Card 2 -->
      <article class="pain-card gsap-hidden bg-white/70 p-8 border border-cn-charcoal/8 hover:border-cn-bronze/40 transition-colors duration-500">
        <div class="mb-5">
          <svg class="w-8 h-8 text-cn-green" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
          </svg>
        </div>
        <h3 class="font-seasons text-cn-charcoal mb-3" style="font-size: clamp(1.25rem, 2.5vw, 1.6rem);">Un coût que peu mesurent</h3>
        <p class="font-inria text-cn-charcoal/65 text-base leading-relaxed">
          Turn-over, absentéisme, réunions stériles : le désengagement coûte en moyenne 15 000 € par collaborateur et par an.
        </p>
      </article>

      <!-- Card 3 -->
      <article class="pain-card gsap-hidden bg-white/70 p-8 border border-cn-charcoal/8 hover:border-cn-bronze/40 transition-colors duration-500">
        <div class="mb-5">
          <svg class="w-8 h-8 text-cn-sage" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <h3 class="font-seasons text-cn-charcoal mb-3" style="font-size: clamp(1.25rem, 2.5vw, 1.6rem);">La cohésion ne se décrète pas</h3>
        <p class="font-inria text-cn-charcoal/65 text-base leading-relaxed">
          Un team building ponctuel ne soude pas une équipe. Il faut un cadre, une méthode, et un ancrage hors du quotidien.
        </p>
      </article>
    </div>

  </div>
  </div>
</section>
