---
---
<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
  aria-label="Section d'accueil"
>
  <!-- Background Image -->
  <div
    id="hero-bg"
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/falaises-plage.jpg');"
    aria-hidden="true"
  ></div>

  <!-- Overlays -->
  <div class="absolute inset-0 bg-cn-green/50" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-cn-charcoal/60 via-transparent to-transparent" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-10 pt-32 pb-24">
    <!-- Eyebrow -->
    <p id="hero-eyebrow" class="gsap-hidden font-montserrat text-cn-bronze text-xs tracking-[0.25em] uppercase mb-6">
      Séminaires stratégiques pour les entreprises
    </p>

    <!-- Devise -->
    <p class="gsap-hidden font-seasons text-cn-cream/60 text-sm italic mb-2 tracking-wide" id="hero-devise">
      Lien &middot; Simplicité &middot; Impact
    </p>

    <!-- Headline -->
    <h1 id="hero-headline" class="gsap-hidden font-seasons text-cn-cream mb-6 max-w-3xl" style="font-size: clamp(3rem, 7vw, 5.5rem); line-height: 1.05; letter-spacing: -0.02em;">
      Réparez la trame<br />
      <em class="not-italic text-cn-bronze">de votre équipe</em>
    </h1>

    <!-- Subheadline -->
    <p id="hero-sub" class="gsap-hidden font-inria text-cn-cream/85 leading-relaxed mb-10 max-w-xl" style="font-size: clamp(1.1rem, 2vw, 1.35rem);">
      Séminaires clé en main en Normandie —<br class="hidden sm:block" />
      2 jours pour transformer la dynamique collective
    </p>

    <!-- CTAs -->
    <div id="hero-cta" class="gsap-hidden flex flex-col sm:flex-row gap-4">
      <a
        href="#diagnostic"
        class="inline-flex items-center justify-center gap-3 px-7 py-4 bg-cn-bronze text-cn-green font-montserrat text-sm tracking-widest uppercase hover:bg-cn-cream transition-colors duration-300 group"
        style="min-height: 52px;"
      >
        Démarrer le diagnostic
        <span class="text-base transition-transform duration-300 group-hover:translate-x-1">→</span>
        <span class="text-cn-green/60 text-xs normal-case tracking-normal">(5 min)</span>
      </a>
      <a
        href="#solution"
        class="inline-flex items-center justify-center gap-3 px-7 py-4 border border-cn-cream/40 text-cn-cream font-montserrat text-sm tracking-widest uppercase hover:border-cn-cream hover:bg-cn-cream/10 transition-all duration-300"
        style="min-height: 52px;"
      >
        Découvrir l'approche
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="gsap-hidden absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-cn-cream/40">
    <span class="font-montserrat text-[10px] tracking-[0.3em] uppercase">Défiler</span>
    <div class="w-px h-12 bg-cn-cream/20 relative overflow-hidden">
      <div id="scroll-line" class="absolute top-0 left-0 right-0 h-1/2 bg-cn-bronze"></div>
    </div>
  </div>
</section>
