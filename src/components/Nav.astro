---
---
<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-10 py-5 transition-all duration-500"
  aria-label="Navigation principale"
>
  <a href="/" aria-label="Séjours littéraires Normandie — Retour en haut">
    <span class="font-seasons text-xl font-bold text-wb-cream">Séjours <span class="hidden sm:inline">littéraires</span></span>
  </a>

  <!-- Desktop nav -->
  <ul class="hidden md:flex items-center gap-8 font-montserrat text-xs tracking-widest uppercase text-wb-cream">
    <li><a href="/sejour-ecriture" class="hover:text-wb-gold transition-colors duration-300">Séjour Écriture</a></li>
    <li><a href="/sejour-lecture" class="hover:text-wb-gold transition-colors duration-300">Séjour Lecture</a></li>
    <li>
      <a
        href="/#sejours"
        class="ml-2 px-5 py-2.5 border border-wb-gold text-wb-gold hover:bg-wb-gold hover:text-wb-ink transition-all duration-300"
      >
        Réserver
      </a>
    </li>
  </ul>

  <!-- Mobile hamburger -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col gap-1.5 p-2 text-wb-cream"
    aria-label="Ouvrir le menu"
    aria-expanded="false"
  >
    <span id="ham-1" class="block w-6 h-px bg-current transition-transform duration-300 origin-center"></span>
    <span id="ham-2" class="block w-6 h-px bg-current transition-opacity duration-300"></span>
    <span id="ham-3" class="block w-4 h-px bg-current transition-transform duration-300 origin-center"></span>
  </button>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-wb-ink flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-400"
  aria-hidden="true"
>
  <ul class="flex flex-col items-center gap-8 text-center">
    <li><a href="/sejour-ecriture" class="mobile-link font-seasons text-4xl text-wb-cream hover:text-wb-gold transition-colors">Séjour Écriture</a></li>
    <li><a href="/sejour-lecture" class="mobile-link font-seasons text-4xl text-wb-cream hover:text-wb-gold transition-colors">Séjour Lecture</a></li>
  </ul>
  <a
    href="/#sejours"
    id="mobile-cta"
    class="mobile-link px-8 py-4 bg-wb-bordeaux text-wb-cream font-montserrat text-sm tracking-widest uppercase"
  >
    Réserver
  </a>
</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const ham1 = document.getElementById('ham-1');
  const ham2 = document.getElementById('ham-2');
  const ham3 = document.getElementById('ham-3');
  let open = false;

  function openMenu() {
    open = true;
    menu!.classList.remove('opacity-0', 'pointer-events-none');
    menu!.classList.add('opacity-100');
    menu!.setAttribute('aria-hidden', 'false');
    toggle!.setAttribute('aria-expanded', 'true');
    ham1!.style.transform = 'translateY(7px) rotate(45deg)';
    ham2!.style.opacity = '0';
    ham3!.style.transform = 'translateY(-7px) rotate(-45deg)';
    ham3!.style.width = '24px';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    open = false;
    menu!.classList.add('opacity-0', 'pointer-events-none');
    menu!.classList.remove('opacity-100');
    menu!.setAttribute('aria-hidden', 'true');
    toggle!.setAttribute('aria-expanded', 'false');
    ham1!.style.transform = '';
    ham2!.style.opacity = '';
    ham3!.style.transform = '';
    ham3!.style.width = '';
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => open ? closeMenu() : openMenu());

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
