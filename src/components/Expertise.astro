---
---
<section
  id="expertise"
  class="bg-white py-28 md:py-section overflow-hidden"
  aria-labelledby="expertise-heading"
>
  <div class="px-6 md:px-10">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

    <!-- Left: Text -->
    <div class="min-w-0 w-full" style="max-width: calc(100vw - 3rem);">
      <p class="font-montserrat text-cn-sage text-xs tracking-[0.25em] uppercase mb-4">L'experte</p>
      <h2 id="expertise-heading" class="font-seasons text-cn-green mb-8" style="font-size: clamp(2.2rem, 4vw, 3.5rem); line-height: 1.1;">
        15 ans à cultiver<br />
        <em class="not-italic text-cn-bronze">l'art du collectif</em>
      </h2>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 gap-5 mb-10">
        <div class="expertise-stat border-l-2 border-cn-bronze pl-4">
          <div class="flex items-baseline gap-1">
            <span class="font-seasons text-4xl text-cn-green stat-val" data-target="15" data-suffix=" ans">15</span>
            <span class="font-seasons text-xl text-cn-bronze">ans</span>
          </div>
          <p class="font-inria text-cn-charcoal/55 text-sm leading-snug mt-1">d'expérience en animation collective</p>
        </div>
        <div class="expertise-stat border-l-2 border-cn-bronze pl-4">
          <div class="flex items-baseline gap-1">
            <span class="font-seasons text-4xl text-cn-green">300</span>
            <span class="font-seasons text-xl text-cn-bronze">+</span>
          </div>
          <p class="font-inria text-cn-charcoal/55 text-sm leading-snug mt-1">Ateliers animés</p>
        </div>
        <div class="expertise-stat border-l-2 border-cn-bronze pl-4">
          <div class="flex items-baseline gap-1">
            <span id="stat-10k" class="font-seasons text-4xl text-cn-green" data-target="10000">0</span>
            <span class="font-seasons text-xl text-cn-bronze">+</span>
          </div>
          <p class="font-inria text-cn-charcoal/55 text-sm leading-snug mt-1">visiteurs aux salons organisés</p>
        </div>
        <div class="expertise-stat border-l-2 border-cn-bronze pl-4">
          <div class="flex items-baseline gap-1">
            <span id="stat-47" class="font-seasons text-4xl text-cn-green" data-target="47">0</span>
            <span class="font-seasons text-xl text-cn-bronze">%</span>
          </div>
          <p class="font-inria text-cn-charcoal/55 text-sm leading-snug mt-1">de ROI en plus pour les entreprises investissant en communication interne</p>
        </div>
      </div>

      <!-- Quote -->
      <blockquote id="expertise-quote" class="relative pl-6 py-4">
        <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-cn-bronze"></div>
        <p class="font-seasons italic text-cn-green leading-snug mb-3" style="font-size: clamp(1.4rem, 2.5vw, 1.9rem);">
          "La performance naît<br />de la qualité du lien"
        </p>
        <footer class="font-montserrat text-cn-charcoal/50 text-xs tracking-widest uppercase">
          Célie Adamczyk &mdash; Fondatrice de Cohésion Normandie
        </footer>
      </blockquote>

      <!-- Maslow reference -->
      <p class="font-inria text-cn-charcoal/60 text-sm mt-6 leading-relaxed border-t border-cn-charcoal/10 pt-6">
        Approche ancrée dans la <strong class="text-cn-green font-semibold">Pyramide de Maslow</strong> :
        la sécurité relationnelle comme fondation de toute haute performance collective.
      </p>
    </div>

    <!-- Right: Portrait -->
    <div id="expertise-portrait" class="relative gsap-hidden-x order-first lg:order-last">
      <div class="relative overflow-hidden aspect-[3/4] max-w-sm mx-auto lg:max-w-none">
        <img
          src="/images/portrait1.jpg"
          alt="Célie Adamczyk — Fondatrice de Cohésion Normandie"
          class="w-full h-full object-cover object-top"
          loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 w-28 h-28 border-2 border-cn-bronze/30 pointer-events-none hidden sm:block"></div>
      </div>
      <div class="absolute -bottom-2 left-0 sm:left-6 bg-cn-green px-5 py-3">
        <p class="font-montserrat text-cn-cream text-xs tracking-[0.2em] uppercase">Architecte du collectif</p>
      </div>
    </div>

  </div>
  </div>
</section>
