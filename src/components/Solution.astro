---
---
<section
  id="solution"
  class="bg-cn-green py-28 md:py-section overflow-hidden"
  aria-labelledby="solution-heading"
>
  <div class="px-6 md:px-10">
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

    <!-- Left: Content -->
    <div class="min-w-0 w-full" style="max-width: calc(100vw - 3rem);">
      <p class="solution-reveal gsap-hidden-x font-montserrat text-cn-sage text-xs tracking-[0.25em] uppercase mb-4">
        L'approche
      </p>
      <h2 id="solution-heading" class="solution-reveal gsap-hidden-x font-seasons text-cn-cream mb-6" style="font-size: clamp(2.2rem, 4vw, 3.5rem); line-height: 1.1;">
        Une parenthèse stratégique,<br />
        <em class="not-italic text-cn-bronze">hors cadre</em>
      </h2>
      <p class="solution-reveal gsap-hidden-x font-inria text-cn-cream/75 text-lg leading-relaxed mb-12 max-w-prose">
        Deux jours, une nuit, en immersion totale dans un manoir normand.
        Loin des open spaces et des écrans, votre équipe retrouve l'essentiel :
        la qualité du lien humain.
      </p>

      <!-- Timeline steps -->
      <ol class="space-y-6">
        <li class="step-item flex gap-6 items-start group">
          <span class="font-montserrat text-cn-bronze text-sm tracking-widest pt-1 flex-shrink-0 w-8">01</span>
          <div class="border-t border-cn-cream/15 pt-4 flex-1 group-hover:border-cn-bronze/50 transition-colors duration-500">
            <h3 class="font-seasons text-cn-cream text-xl mb-1">Arrivée &amp; ancrage</h3>
            <p class="font-inria text-cn-cream/55 text-sm leading-relaxed">Accueil au manoir, déjeuner commun, mise en contexte collective</p>
          </div>
        </li>
        <li class="step-item flex gap-6 items-start group">
          <span class="font-montserrat text-cn-bronze text-sm tracking-widest pt-1 flex-shrink-0 w-8">02</span>
          <div class="border-t border-cn-cream/15 pt-4 flex-1 group-hover:border-cn-bronze/50 transition-colors duration-500">
            <h3 class="font-seasons text-cn-cream text-xl mb-1">Ateliers de fond</h3>
            <p class="font-inria text-cn-cream/55 text-sm leading-relaxed">4 séquences sur la communication, le conflit, la vision partagée</p>
          </div>
        </li>
        <li class="step-item flex gap-6 items-start group">
          <span class="font-montserrat text-cn-bronze text-sm tracking-widest pt-1 flex-shrink-0 w-8">03</span>
          <div class="border-t border-cn-cream/15 pt-4 flex-1 group-hover:border-cn-bronze/50 transition-colors duration-500">
            <h3 class="font-seasons text-cn-cream text-xl mb-1">Soirée de cohésion</h3>
            <p class="font-inria text-cn-cream/55 text-sm leading-relaxed">Expérience conviviale, dîner gastronomique normand, rituel de groupe</p>
          </div>
        </li>
        <li class="step-item flex gap-6 items-start group">
          <span class="font-montserrat text-cn-bronze text-sm tracking-widest pt-1 flex-shrink-0 w-8">04</span>
          <div class="border-t border-cn-cream/15 pt-4 flex-1 group-hover:border-cn-bronze/50 transition-colors duration-500">
            <h3 class="font-seasons text-cn-cream text-xl mb-1">Restitution &amp; engagement</h3>
            <p class="font-inria text-cn-cream/55 text-sm leading-relaxed">Synthèse collective, pacte d'équipe, plan d'action à 90 jours</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Right: Image -->
    <div class="solution-image relative h-72 lg:h-[600px] overflow-hidden order-first lg:order-last">
      <img
        src="/images/champs.jpg"
        alt="Paysage normand, champs verts sous ciel nuageux"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-cn-green/20"></div>
      <div class="absolute inset-4 border border-cn-cream/15 pointer-events-none"></div>
    </div>

  </div>
  </div>
</section>
