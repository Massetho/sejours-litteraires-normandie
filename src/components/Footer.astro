---
---
<footer
  class="bg-wb-ink border-t border-wb-cream/10 py-12"
  aria-label="Pied de page"
>
  <div class="max-w-6xl mx-auto px-6 md:px-10">

    <!-- Top row: Logo + Social -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 pb-8 border-b border-wb-cream/10">

      <!-- Logo + tagline -->
      <div class="flex items-center gap-4">
        <div class="h-8 w-px bg-wb-cream/20"></div>
        <div>
          <p class="font-seasons text-wb-cream text-base">Séjours littéraires Normandie</p>
          <p class="font-lora text-wb-cream/45 text-xs italic tracking-wide">Parenthèses d'Hiver · Déconnexion · Écriture · Lecture</p>
        </div>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-5">
        <!-- Site principal -->
        <a
          href="https://celiea.fr/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-wb-cream/50 hover:text-wb-gold transition-colors duration-300"
          aria-label="Site principal de Célie Adamczyk"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/c%C3%A9lie-adamczyk-512ba991/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-wb-cream/50 hover:text-wb-gold transition-colors duration-300"
          aria-label="LinkedIn de Célie Adamczyk"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href="https://www.instagram.com/celie_adamczyk"
          target="_blank"
          rel="noopener noreferrer"
          class="text-wb-cream/50 hover:text-wb-gold transition-colors duration-300"
          aria-label="Instagram de Célie Adamczyk"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>

        <!-- Spotify Podcast -->
        <a
          href="https://open.spotify.com/show/2zaREcWo8cOaD8LMi8sd1K"
          target="_blank"
          rel="noopener noreferrer"
          class="text-wb-cream/50 hover:text-wb-gold transition-colors duration-300"
          aria-label="Podcast Spotify de Célie Adamczyk"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8">
      <nav aria-label="Liens légaux">
        <ul class="flex flex-wrap justify-center gap-6 font-montserrat text-xs tracking-widest uppercase text-wb-cream/40">
          <li>
            <a href="mailto:Celie.octopuscreatio@gmail.com" class="hover:text-wb-gold transition-colors">Contact</a>
          </li>
          <li>
            <a href="/cgv" class="hover:text-wb-gold transition-colors">CGV</a>
          </li>
        </ul>
      </nav>
      <p class="font-lora text-wb-cream/30 text-xs italic">
        &copy; {new Date().getFullYear()} Séjours littéraires Normandie
      </p>
    </div>

  </div>
</footer>
