---
<section
  id="diagnostic"
  class="relative py-28 md:py-36 overflow-hidden"
  aria-label="Appel à l'action — Démarrer le diagnostic"
>
  <!-- Background parallax image -->
  <div
    id="cta-bg"
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('/images/falaises.jpg');"
    aria-hidden="true"
  ></div>
  <!-- Heavy overlay -->
  <div class="absolute inset-0 bg-cn-green/80"></div>

  <!-- Content -->
  <div class="relative z-10 px-6 md:px-10">
  <div class="max-w-3xl mx-auto text-center">
    <p class="cta-reveal gsap-hidden font-montserrat text-cn-bronze text-xs tracking-[0.3em] uppercase mb-6">
      Passez à l'action
    </p>
    <h2 class="cta-reveal gsap-hidden font-seasons text-cn-cream mb-6" style="font-size: clamp(2.2rem, 4vw, 3.5rem); line-height: 1.1;">
      Prêt à transformer<br />la dynamique de votre équipe ?
    </h2>
    <p class="cta-reveal gsap-hidden font-inria text-cn-cream/70 text-lg leading-relaxed mb-10">
      5 minutes de questionnaire.<br />
      1 semaine pour vous rappeler avec un programme sur mesure.
    </p>
    <div class="cta-reveal gsap-hidden">
      <a
        id="cta-button"
        href="mailto:celie.octopuscreatio@gmail.com?subject=Demande%20de%20diagnostic%20%E2%80%94%20Cohésion%20Normandie"
        class="inline-flex items-center gap-3 px-9 py-5 bg-cn-bronze text-cn-green font-montserrat text-sm tracking-widest uppercase hover:bg-cn-cream transition-colors duration-300 group"
        style="min-height: 56px;"
      >
        Démarrer le diagnostic
        <span class="text-lg transition-transform duration-300 group-hover:translate-x-2">→</span>
      </a>
    </div>
    <p class="cta-reveal gsap-hidden font-montserrat text-cn-cream/35 text-xs mt-5 tracking-wide">
      Sans engagement &middot; Réponse sous 7 jours ouvrés
    </p>

    <!-- Contact details -->
    <div class="cta-reveal gsap-hidden flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mt-10 pt-8 border-t border-cn-cream/15">
      <a
        href="mailto:celie.octopuscreatio@gmail.com"
        class="flex items-center gap-2 font-montserrat text-cn-cream/60 text-xs tracking-wide hover:text-cn-bronze transition-colors duration-300"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        celie.octopuscreatio@gmail.com
      </a>
      <a
        href="tel:+33615720204"
        class="flex items-center gap-2 font-montserrat text-cn-cream/60 text-xs tracking-wide hover:text-cn-bronze transition-colors duration-300"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        06 15 72 02 04
      </a>
    </div>
  </div>
  </div>
</section>
